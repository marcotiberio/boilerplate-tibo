{
    "name": "kreisler/sage-theme",
    "type": "wordpress-theme",
    "license": "MIT",
    "description": "Sage-based WordPress theme with ACF Gutenberg blocks",
    "require": {
        "php": ">=8.1",
        "roots/acorn": "^4.0"
    },
    "require-dev": {},
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "roots/wordpress-core-installer": true
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Roots\\Acorn\\ComposerScripts::postAutoloadDump"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
