<flynt-component load:on="visible" name="BlockAccordionDefault" class="scroll-mt-24" id="artistCurriculum">
  <div class="boxed flex flex-col gap-sm">
    {% if blockTitleHtml %}
      <div class="font-h2">
        {{ blockTitleHtml|e('wp_kses_post') }}
      </div>
    {% endif %}
    <div class="list-none flex flex-col flex-wrap gap-xs">
      {% for panel in accordionPanels %}
        <div x-data="{ open: false }" class="bg-grey-100 text-black rounded-[12px]">
          <button @click="open = !open" class="items-center cursor-pointer flex font-extrabold justify-between m-0 p-[20px] relative w-full z-[2]" type="button" aria-expanded="false" aria-controls="content-{{ loop.index }}">
            <div class="">{{ panel.panelTitle|e }}</div>
            <div class="min-w-[40px] flex items-center justify-end">
              {% include 'assets/icons/chevron-down.svg' ignore missing %}
            </div>
          </button>
          <div x-show="open" class="mx-auto p-[20px] transition-all duration-300 ease-in-out z-[1]" aria-hidden="true" id="content-{{ loop.index }}">
            <div class="p-0 wysiwyg">
              {{ panel.panelContent|e('wp_kses_post') }}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</flynt-component>
