<flynt-component 
  load:on="visible" 
  name="BlockWysiwyg"
  id="{{ options.componentLabel|lower|replace({' ': '-'}) }}"
  style="
    color: {% if options.colorText %}{{ options.colorText }}{% else %}var(--black){% endif %};">
  <div 
    class="boxed md:boxed--small w-screen md:min-h-screen flex justify-center items-center">
    {% if options.componentLabel %}
    <div class="boxed boxed--small absolute top-0 left-0 w-full flex justify-between items-center">
      <div class="font-menu">{{ options.componentLabel }}</div>
      <div class="font-menu">{{ options.componentLabel }}</div>
    </div>
    {% endif %}
    <div 
      class="
        wysiwyg flex flex-col {% if options.colorBackground %} p-sm rounded {% endif %}
        {% if textPosition == 'right' %} justify-end w-full ml-auto{% endif %}
        {% if textPosition == 'left' %} justify-start w-full mr-auto{% endif %}
        {% if textPosition == 'center' %} justify-center w-full mx-auto{% endif %}
      "
      style="background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}transparent{% endif %};">
      {{ contentHtml|e('wp_kses_post') }}
    </div>
  </div>
</flynt-component>
