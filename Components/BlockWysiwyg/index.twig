<flynt-component 
  load:on="visible" 
  name="BlockWysiwyg">
  <div
    class="boxed {% if options.topBorder %}border-t-2 border-black mt-sm{% endif %}">
    <div 
      class="boxed--inner px-sm py-sm
        {% if options.stickyText %}stickyText{% endif %}
        wysiwyg flex flex-col
        {% if textPosition == 'right' %} justify-end w-full lg:w-[calc(75%_-_12.5px)] ml-auto{% endif %}
        {% if textPosition == 'left' %} justify-start w-full lg:w-[calc(75%_-_12.5px)] mr-auto{% endif %}
        {% if textPosition == 'center_narrow' %} justify-center w-full md:w-2/3 mx-auto{% endif %}
        {% if textPosition == 'center_full' %} justify-center w-full mx-auto{% endif %}
      "
      style="background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}transparent{% endif %};">
      {{ contentHtml|e('wp_kses_post') }}
      {% if buttonLink %}
        <a 
          class="button button--outline" 
          href="{{ buttonLink.url }}" 
          {% if buttonLink.target %} target="{{ buttonLink.target }}" rel="noreferrer noopener"{% endif %}>
          {{ buttonLink.title }}
        </a>
      {% endif %}
    </div>
  </div>
</flynt-component>
