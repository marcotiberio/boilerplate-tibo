<flynt-component 
  load:on="idle"
  {# client:media="(max-width: 1023px)" #}
  name="NavigationBurger"
  class="block lg:hidden fixed top-0 left-0 w-screen z-50 flex-row justify-between mx-auto">
  <nav aria-label="{{ labels.ariaLabel|e }}" class="h-auto w-full">
    <div class="w-full h-full max-w-screen-box mx-auto !px-xs md:!px-sm !min-h-full grid grid-cols-2 lg:gap-sm align-middle items-center z-[3001] relative">
      {% include 'Partials/_logo.twig' with { 'logo': logo, 'site': site } only %}
      {% if menu %}
        <div class="flex justify-end items-center">
          {% include 'Partials/_hamburger.twig' with { 'labels': labels } only %}
        </div>
      {% endif %}
    </div>
    {% if menu %}
      <div
        data-ref="menu" 
        class="menu w-full h-full fixed top-0 overflow-y-hidden p-0 !pt-[50px] m-0 flex flex-col sm:flex-row justify-start items-center sm:items-start bg-beige z-40">
        <div class="w-full h-fit max-w-screen-box mx-auto flex flex-col justify-start items-start gap-sm px-xs py-sm">
          {% for item in menu.items %}
            {# regular menu item #}
            {% if not item.children %}
              <div class="item {{ item.classes|join(' ') }} {{- item.current ? ' current-menu-item underline underline-offset-4' }}">
                <a class="link font-nav no-underline text-center" href="{{ item.link }}" {{ item.target == '_blank' ? 'target="_blank" rel="noopener noreferrer"' }}>
                  {{ item.title }}
                </a>
              </div>
            {% endif %}
            {# menu with submenu item #}
            {% if item.children %}
              <div class="item open-submenu w-full p-0 flex flex-col justify-between items-center gap-[10px] {{ item.classes|join(' ') }} {{- item.current ? ' current-menu-item underline underline-offset-4' }}" >
                <a class="link font-nav no-underline" href="{{ item.link }}" {{ item.target == '_blank' ? 'target="_blank" rel="noopener noreferrer"' }}>
                  {{ item.title }}
                </a>
                <div class="submenu w-full flex flex-row flex-wrap justify-center items-center gap-sm">
                  {% for subitem in item.children %}
                    <div class="item {{ item.classes|join(' ') }} {{- subitem.current ? ' current-menu-item underline underline-offset-4' }}">
                      <a class="link !p-0 font-nav no-underline" href="{{ subitem.link }}" {{ subitem.target == '_blank' ? 'target="_blank" rel="noopener noreferrer"' }}>{{ subitem.title }}</a>
                    </div>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
        {% if menuBurgerSecondary %}
          <div class="w-full max-w-screen-box mx-auto flex flex-row justify-center gap-sm px-xs py-sm">
            {% for item in menuBurgerSecondary.items %}
              <div class="item w-fit {{ item.classes|join(' ') }}">
                <a class="link font-nav scale-75 no-underline" href="{{ item.link }}" {{ item.target == '_blank' ? 'target="_blank" rel="noopener noreferrer"' }}>
                  {{ item.title }}
                </a>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </nav>
</flynt-component>
