{% if posts|length > 0 %}
  <flynt-component 
    load:on="visible" 
    name="ListingNews" 
    class=""
    style="
      color: {% if options.colorText %}{{ options.colorText }}{% else %}var(--black){% endif %};
      background-color: {% if options.pageBackground %}{{ options.pageBackground }}{% else %}transparent{% endif %};">
    
    <div class="boxed flex flex-col gap-sm" x-data="{ 
      selectedCategory: '', 
      searchQuery: '', 
      filtersOpen: false,
      isTransitioning: false,
      transitionDelay: 150
    }">
      {# <div class="grid grid-cols-12 gap-xs">
        
        <div class="flex flex-col flex-wrap justify-start col-start-1 col-end-13 lg:col-start-8">
          
          <!-- All Category Filter -->
          <div 
            class="font-body !mb-0 cursor-pointer hover:text-black w-fit"
            :class="selectedCategory === '' ? 'text-black' : ''"
            @click="
              if (selectedCategory !== '') {
                isTransitioning = true;
                setTimeout(() => {
                  selectedCategory = '';
                  setTimeout(() => isTransitioning = false, transitionDelay);
                }, transitionDelay);
              }
            ">
            All
          </div>
          
          {% set journalCategories = [
            {'name': 'Events', 'slug': 'events'},
            {'name': 'Longreads', 'slug': 'longreads'},
            {'name': 'News', 'slug': 'news'},
            {'name': 'Resources', 'slug': 'resources'},
          ] %}
          {% for journalCategory in journalCategories %}
            <div 
              class="font-body !mb-0 cursor-pointer hover:text-black w-fit"
              :class="selectedCategory === '{{ journalCategory.slug }}' ? 'text-black' : ''"
              @click="
                if (selectedCategory !== '{{ journalCategory.slug }}') {
                  isTransitioning = true;
                  setTimeout(() => {
                    selectedCategory = '{{ journalCategory.slug }}';
                    setTimeout(() => isTransitioning = false, transitionDelay);
                  }, transitionDelay);
                }
              ">
              {{ journalCategory.name }}
            </div>
          {% endfor %}
        </div>            

      </div> #}

      <!-- Posts Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-sm">
        {% for post in posts %}
          {# {% set journalCategoryTerms = post.terms('journal-category') %}
          {% set allTerms = journalCategoryTerms %}
          {% set hardcodedCategories = {
            'Events': 'events',
            'Longreads': 'longreads',
            'News': 'news',
            'Resources': 'resources'
          } %}
          {% set postCategorySlugs = allTerms|map(term => hardcodedCategories[term.name]|default(term.name|lower|replace({' ' : '-'}))) %} #}

          <div 
            class="post w-full py-sm [&_img]:hover:shadow-[0px_0px_20px_0px_#3d6bff] hover:cursor-pointer transition-all duration-300 ease-in-out" 
            x-show="(selectedCategory === '' || ['{{ postCategorySlugs|join("','") }}'].includes(selectedCategory)) && 
                     (searchQuery === '' || '{{ post.title|lower }}'.includes(searchQuery.toLowerCase()))"
            :class="isTransitioning ? 'opacity-0' : 'opacity-100'"
          >
            <a class="no-underline" href="{{ post.link }}" title="{{ post.title }}" aria-label="Go to post">
              <div class="w-full flex flex-col gap-xs items-start">
                {% if post.thumbnail %}
                  <img 
                    class="lazyload aspect-4/3 object-cover rounded-image transition-all duration-300 ease-in-out"
                    src="{{ post.thumbnail.src }}"
                    alt="{{ post.thumbnail.alt|e | default('') }}"
                    loading="lazy"
                    style="opacity: 0; transition: opacity 0.5s ease-in-out;"
                    onload="this.style.opacity='1'"
                    aria-label="Go to post"
                  />
                {% endif %}
                <div class="font-bodySmall !mb-0 col-start-4 col-end-5 flex flex-row gap-xs items-center">
                  <span class="font-bodySmall !mb-0">{{ post.postDate|date('d.m.Y') }}</span>
                  {# <div class="flex lg:hidden nd-11">
                    {% for term in allTerms %}
                      <span class="font-label">{{ term.name }}</span>
                    {% endfor %}
                  </div> #}
                </div>

                <div class="w-full h-full flex flex-col justify-between !mb-0 col-start-5 col-end-8">
                  <h2 class="w-full !mb-0">{{ post.title }}</h2>
                </div>
                
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    </div>

  </flynt-component>
{% endif %}