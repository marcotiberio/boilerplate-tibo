<flynt-component
  load:on="visible" name="HeroHeaderHome"
  class="w-full lgplus:w-screen {{ height|default('h-screen') }} mx-auto relative overflow-hidden">
  {% if videoIDLandscape %}
    <div class="video hidden lgplus:block">
      <div data-ref="videoPlayer" class="video-player w-full mx-auto" data-state="isLoaded">
        <iframe 
          src="https://player.vimeo.com/video/{{ videoIDLandscape }}?badge=0&amp;autopause=0&amp;player_id=0&amp;app_id=58479&amp;autoplay=1&amp;muted=1&amp;loop=1&amp;controls=0&amp;background=1"
          frameborder="0" 
          allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share" 
          referrerpolicy="strict-origin-when-cross-origin" 
          title="Hero Video"></iframe>
      </div>
    </div>
  {% endif %}
  {% if image %}
    <img 
      data-ref="backgroundImageDesktop"
      class="hidden lgplus:block figure-image w-full h-full object-cover"
      src="{{ image.src }}"
      alt="{{ image.alt|e | default('') }}"
      loading="eager"
    />
  {% endif %}
  {% if videoIDPortrait %}
    <div class="video block lgplus:hidden scale-[1.45] lg:scale-[3.5] lgplus:scale-100">
      <div data-ref="videoPlayer" class="video-player w-full mx-auto" data-state="isLoaded">
        <iframe 
          src="https://player.vimeo.com/video/{{ videoIDPortrait }}?badge=0&amp;autopause=0&amp;player_id=0&amp;app_id=58479&amp;autoplay=1&amp;muted=1&amp;loop=1&amp;controls=0&amp;background=1"
          frameborder="0" 
          allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share" 
          referrerpolicy="strict-origin-when-cross-origin" 
          title="Hero Video"></iframe>
      </div>
    </div>
  {% endif %}
  {% if imageMobile %}
    <img 
      data-ref="backgroundImageMobile"
      class="block lgplus:hidden figure-image w-full h-full object-cover"
      src="{{ imageMobile.src }}"
      alt="{{ imageMobile.alt|e | default('') }}"
      loading="eager"
    />
  {% endif %}
  <div class="gradient-overlay absolute inset-0 z-10 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-full z-20">
    <div class="boxed px-xs py-sm md:p-sm flex flex-col gap-sm">
      <div class="wysiwyg">{{ titleHtml|e('wp_kses_post') }}</div>
      {% if buttonLink %}
        <a class="button button--fullRed" href="{{ buttonLink.url }}" target="{{ buttonLink.target }}" rel="noreferrer noopener">
          {{ buttonLink.title }}
        </a>
      {% endif %}
    </div>
  </div>
</flynt-component>
