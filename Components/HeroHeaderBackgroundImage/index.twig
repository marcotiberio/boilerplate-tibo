<flynt-component
  load:on="idle" 
  name="HeroHeaderBackgroundImage" 
  class="overflow-hidden" 
  style="
    color: {% if options.colorText %}{{ options.colorText }}{% else %}var(--black){% endif %};
    background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}transparent{% endif %};"
  >
  <div class="relative boxed--large flex flex-col justify-center items-center gap-sm h-[calc(100svh-82px)]">
    {% if backgroundImage %}
      <img 
        class="w-full h-full object-cover absolute top-0 left-0 z-0"
        src="{{ backgroundImage.src }}" 
        alt="{{ backgroundImage.alt | default('') }}" 
        loading="lazy"
      >
    {% endif %}
    {% if textHtml %}
      <div class="wysiwyg text-center z-10">{{ textHtml|e('wp_kses_post') }}</div>
    {% endif %}
    {% if buttonLink %}
      <a 
        class="button button--fullOrange" 
        href="{{ buttonLink.url }}" 
        {% if buttonLink.target %} target="{{ buttonLink.target }}" rel="noreferrer noopener"{% endif %}>
        {{ buttonLink.title }}
      </a>
    {% endif %} 
  </div>
</flynt-component>
