<flynt-component 
  load:on="visible" 
  name="BlockBannerShape"
  style="
    background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}transparent{% endif %};
    color: {% if options.colorText %}{{ options.colorText }}{% else %}var(--blue){% endif %};">
  <div 
    class="boxed w-full relative min-h-[575px] lg:min-h-[610px] flex items-center justify-center">
    {% if backgroundImageMobile %}
      <div class="flex lg:hidden absolute inset-0 w-full h-full z-0 pointer-events-none max-w-full max-h-full items-center justify-center">
        <img class="figure-image lazyload h-full w-full max-w-[800px] object-cover"
          src="{{ backgroundImageMobile.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', backgroundImageMobile.id)}}"
          data-sizes="auto"
          alt="{{ backgroundImageMobile.alt|e }}">
      </div>
    {% endif %}
    {% if backgroundImage %}
      <div class="hidden lg:flex absolute inset-0 w-full h-full z-0 pointer-events-none max-w-full max-h-full items-center justify-center">
        <img class="figure-image lazyload h-full w-full max-w-[800px] object-cover"
          src="{{ backgroundImage.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', backgroundImage.id)}}"
          data-sizes="auto"
          alt="{{ backgroundImage.alt|e }}">
      </div>
    {% endif %}
    <div class="relative z-10 w-full h-full flex flex-col justify-center gap-sm mx-auto max-w-sm lg:max-w-md {% if contentAlignment == 'left' %} items-start text-left {% elseif contentAlignment == 'right' %} items-end text-right {% else %} items-center text-center {% endif %}">
      <div class="wysiwyg">{{ contentHtml|e('wp_kses_post') }}</div>
      {% if buttonLink %}
        <a 
          class="button button--{{ buttonStyle|default('fullBlue') }}" 
          href="{{ buttonLink.url }}" 
          {% if buttonLink.target %} target="{{ buttonLink.target }}" rel="noreferrer noopener"{% endif %}>
          {{ buttonLink.title }}
        </a>
      {% endif %}
    </div>
  </div>
</flynt-component>
