<flynt-component 
  load:on="visible" 
  name="BlockForm"
  style="
    color: {% if options.colorText %}{{ options.colorText }}{% else %}var(--blue){% endif %};">
  <div 
    class="boxed w-full">
    <div 
      class="
        flex flex-col md:flex-row gap-sm {% if options.colorBackground %} p-sm rounded {% endif %}
        {% if textPosition == 'right' %} justify-end w-full ml-auto{% endif %}
        {% if textPosition == 'left' %} justify-start w-full mr-auto{% endif %}
        {% if textPosition == 'center' %} justify-center w-full mx-auto{% endif %}
      "
      style="background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}transparent{% endif %};">
      <div class="w-full md:w-1/2 flex flex-col gap-lg">
        <div class="wysiwyg">{{ contentHtml|e('wp_kses_post') }}</div>
        {% if illustration   %}
        <img class="max-w-[345px] lg:max-w-1/2 lazyload object-cover"
          src="{{ illustration.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', illustration.id)}}"
          data-sizes="auto"
          alt="{{ illustration.alt|e }}">
        {% endif %}
      </div>
      {% if shortcode %}
        <div class="w-full md:w-1/2">
          {{ function('do_shortcode', shortcode) }}
        </div>
      {% endif %}
      {% if embedCode %}
        <div class="w-full md:w-1/2">
          {{ embedCode|raw }}
        </div>
      {% endif %}
    </div>
  </div>
</flynt-component>
