<flynt-component name="BlockShareButtons">
  <div
    x-data="{
      copied: false,
      share() {
        if (navigator.share) {
          navigator.share({
            title: document.title,
            url: window.location.href
          })
        }
      },
      copyLink() {
        navigator.clipboard.writeText(window.location.href)
        this.copied = true
        setTimeout(() => this.copied = false, 2000)
      },
      printPage() {
        window.print()
      }
    }"
    class="w-full py-sm md:py-lg border-t-2 border-black"
  >
    {% if post.meta('shareButtonsTitle') %}
      <h3 class="font-bodyBold text-center mb-xs">{{ post.meta('shareButtonsTitle') }}</h3>
    {% endif %}

    <div class="flex flex-row items-center justify-center gap-xs">
      {# Share button #}
      <button
        x-on:click="share()"
        class="button bg-grei"
      >
        <svg class="w-[18px] h-[18px] mr-min" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="18" cy="5" r="3"/>
          <circle cx="6" cy="12" r="3"/>
          <circle cx="18" cy="19" r="3"/>
          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
          <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
        </svg>
        Teilen
      </button>

      {# Copy link button #}
      <button
        x-on:click="copyLink()"
        class="button bg-grei"
      >
        <svg class="w-[18px] h-[18px] mr-min" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
        </svg>
        <span x-text="copied ? 'Kopiert!' : 'Link kopieren'">Link kopieren</span>
      </button>

      {# Print button #}
      <button
        x-on:click="printPage()"
        class="button bg-grei"
      >
        <svg class="w-[18px] h-[18px] mr-min" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 6 2 18 2 18 9"/>
          <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
          <rect x="6" y="14" width="12" height="8"/>
        </svg>
        Drucken
      </button>
    </div>
  </div>
</flynt-component>
