<flynt-component 
  load:on="visible" name="BlockVideoHeader" 
  class="w-full mx-auto flex flex-col justify-between items-center">
  <div class="w-full">
    <div class="flex flex-col h-full relative">
      <div class="w-full lg:w-full h-full flex flex-col justify-between">
        <div class="grid md:grid-cols-12 gap-xs">
          <div class="w-full md:col-span-6 flex flex-col justify-start gap-xs h-fit md:sticky md:top-[91px]">
            <div class="font-h2 pb-sm">{{ post.title }}</div>
          </div>
          {# <div class="w-full md:col-span-6" style="color: {% if options.colorText %}{{ options.colorText }}{% else %}var(--black){% endif %};">
            <div class="w-full">
              {% if post.thumbnail %}
                <img 
                  class="figure-image object-cover aspect-8/5"
                  src="{{ post.thumbnail.src }}"
                  alt="{{ post.thumbnail.alt|e | default('') }}"
                  loading="lazy"
                  style="opacity: 0; transition: opacity 0.5s ease-in-out;"
                  onload="this.style.opacity='1'"
                />
              {% endif %}
            </div>
          </div> #}
        </div>
      </div>
    </div>
  </div>
</flynt-component>
