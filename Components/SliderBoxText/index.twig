<flynt-component
  load:on="idle" name="SliderBoxText"
  class="pb-0 overflow-hidden"
  style="
    color: {% if options.colorText %}{{ options.colorText }}{% else %}var(--black){% endif %};
    background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}transparent{% endif %};"
  >
  <script type="application/json">{{ jsonData|json_encode }}</script>
  <div class="wrapper w-screen mx-auto boxed pb-xl lg:pb-lg">
    <div class="w-full max-w-screen-box mx-auto flex flex-col">
      {% if headlineTitle %}
      <h2 class="font-h2">{{ headlineTitle }}</h2>
      {% endif %}
      {% if subtitleHtml %}
        <div class="wysiwyg">{{ subtitleHtml|e('wp_kses_post') }}</div>
      {% endif %}
    </div>

    <div data-ref="slider" class="slider swiper-container mt-lg lg:mt-xxl">
      <div class="swiper-wrapper">
        {% for row in rows %}
          <div class="slider-item swiper-slide relative w-full h-auto lg:mr-md flex flex-col lg:flex-row justify-center items-center">;
            <div class="lg:w-1/2 max-w-[80vw] lg:max-w-[20vw] h-full flex justify-end items-center rotate-[-6deg]">
              <img class="lazyload rounded-image aspect-square object-cover"
                style="box-shadow: 0px 4px 32px 0px #00000026;"
                src="{{ row.image.src | resize(32) }}"
                data-srcset="{{function('wp_get_attachment_image_srcset', row.image.id)}}"
                data-sizes="auto"
                alt="{{ row.image.alt|e }}">
            </div>
            <div class="lg:w-1/2 max-w-[80vw] lg:max-w-[20vw] aspect-square rounded-image h-full flex justify-center items-center bg-blue text-white p-xs rotate-[7deg] lg:rotate-[15deg]">
              <div class="text-center font-h4" style="text-shadow: 0px 4px 32px 0px #00000026;">{{ row.text|e('wp_kses_post') }}</div>
            </div>
          </div>
        {% endfor %}
      </div>
      <div class="hidden lg:block w-full button-wrapper absolute left-0 bottom-0 z-50 translate-y-[calc(-10vw+40px)]">
        <div class="w-[60vw] mx-auto flex align-middle justify-between items-center">
          <button type="button" data-ref="prev" class="slider-button slider-button--prev hover:scale-110 transition-transform duration-300">
            {% include 'assets/icons/arrow-prev.svg' ignore missing %}
          </button>
          <button type="button" data-ref="next" class="slider-button slider-button--next hover:scale-110 transition-transform duration-300">
            {% include 'assets/icons/arrow-next.svg' ignore missing %}
          </button>
        </div>
      </div>
    </div>
  </div>
</flynt-component>

