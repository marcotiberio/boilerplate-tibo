<flynt-component
  load:on="visible" name="BlockFeaturedArticle"
  class="w-full lg:w-screen h-screen mx-auto relative overflow-hidden">
  {% if post %}
    <div class="block w-full h-full {% if options.topBorder %}border-t-2 border-black mt-sm{% endif %}">
      {% if halftoneSvg %}
        <div class="halftone-image absolute inset-0 w-full h-full overflow-hidden [&_svg]:absolute [&_svg]:inset-0 [&_svg]:w-full [&_svg]:h-full">
          {{ halftoneSvg|raw }}
        </div>
      {% elseif postImage %}
        <img
          class="figure-image w-full h-full max-h-screen object-cover"
          src="{{ postImage.src }}"
          alt="{{ postImage.alt|e | default('') }}"
          loading="eager"
        />
      {% endif %}
      {# Info Box #}
      <a href="{{ post.link }}" class="w-full absolute bottom-0 no-underline">
        <div class="max-w-screen-tablet mx-auto bg-white p-sm md:p-md flex flex-col justify-center items-center text-center">
          <h1 class="font-h1">{{ post.title }}</h1>
          {% if post.postIntroHomepage %}
            <p class="font-subline mt-min">{{ post.postIntroHomepage }}</p>
          {% else %}
            <p class="font-subline mt-min">{{ post.postIntro }}</p>
          {% endif %}
          <div class="w-full flex flex-row flex-wrap gap-xs items-center justify-center mt-sm">
            <div class="">
              {% set postCategories = post.terms('category') %}
              {% for term in postCategories %}
                <span class="button !mb-0" style="background-color: {{ post.meta('colorBackground')|default('#f1f1f1') }}">{{ term }}{% if not loop.last %},{% endif %}</span>
              {% endfor %}
            </div>
            {% if post.date %}
              <div class="button button--grey pointer-events-none !mb-0">{{ post.date('d.m.Y') }}</div>
            {% endif %}
            {% if post.meta('postAuthor') %}
              {% for author in Post(post.meta('postAuthor')) %}
                <span class="button button--grey pointer-events-none !mb-0">{{ author.title }}</span>
              {% endfor %}
            {% endif %}
          </div>
        </div>
      </a>
    </div>
  {% endif %}
</flynt-component>
