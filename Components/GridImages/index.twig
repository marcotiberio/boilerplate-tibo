<flynt-component 
  load:on="visible" 
  name="GridImages"
  style="background-color:{% if options.colorBackground %}{{ options.colorBackground }}{% else %}var(--transparent){% endif %};">
  <div class="boxed max-w-screen-max mx-auto flex flex-col gap-sm">
    {% if title %}
      <div class="font-h2">{{ title }}</div>
    {% endif %}
    {% set gridColClasses = {
      1: 'grid-cols-1 sm:grid-cols-1 lg:grid-cols-1',
      2: 'grid-cols-2 sm:grid-cols-2 lg:grid-cols-2',
      3: 'grid-cols-3 sm:grid-cols-3 lg:grid-cols-3',
    } %}
    <div 
      class="w-full mx-auto grid {{ gridColClasses[options.gridColumns] ?? gridColClasses[1] }}"
      data-ref="imageGrid">
      {% for item in items %}
        {% if item.image %}
          <figure class="figure figureImage w-full cursor-pointer" data-ref="imageItem" data-image-index="{{ loop.index0 }}">
            <img class="lazyload w-full mx-auto h-auto object-cover aspect-square rounded-image"
              src="{{ item.image.src | resize(32) }}"
              data-srcset="{{function('wp_get_attachment_image_srcset', item.image.id)}}"
              data-sizes="auto"
              data-lightbox-src="{{ item.image.src }}"
              data-lightbox-srcset="{{function('wp_get_attachment_image_srcset', item.image.id)}}"
              alt="{{ item.image.alt|e }}">
          </figure>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</flynt-component>
