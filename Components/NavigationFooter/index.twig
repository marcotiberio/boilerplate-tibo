<flynt-component 
  load:on="visible" 
  name="NavigationFooter" 
  class="boxed boxed--small flex flex-col justify-between items-start gap-sm lg:gap-xxl relative z-20"
  id="{{ componentLabel|lower|replace({' ': '-'}) }}"
  >
  {% if componentLabel %}
    <div class="boxed boxed--small absolute top-0 left-0 w-full flex justify-between items-center">
      <div class="font-menu">{{ componentLabel }}</div>
      <div class="font-menu">{{ componentLabel }}</div>
    </div>
  {% endif %}
  {# Top #}
  <div class="w-full lg:w-1/2 flex flex-row flex-wrap justify-start items-start gap-xl pt-lg">
    <div class="wysiwyg">{{ contentHtml|e('wp_kses_post') }}</div>
  </div>
  {# Center #}
  <div class="w-full">
    <div class="flex flex-col md:flex-row flex-wrap justify-between lg:justify-end items-start gap-sm lg:gap-max">
      {% for column in columns %}
        <div class="wysiwyg">{{ column.contentHtml|e('wp_kses_post') }}</div>
      {% endfor %}
    </div>
  </div>
  {# Bottom #}
  <div class="w-full h-full flex flex-col-reverse lg:flex-row gap-xs lg:gap-sm justify-between items-center mt-md lg:mt-max">
    <div class="font-menu uppercase">{{ copyrightHtml }}</div>
    {% if menu %}
      <nav class="flex justify-end items-center" aria-label="{{ labels.ariaLabel }}">
        {% include 'Partials/_menu.twig' with { 'items': menu.get_items, 'level': '0', 'maxLevel': maxLevel } only %}
      </nav>
    {% endif %}
    {# Logo #}
    <div class="w-fit flex justify-center items-center">
      {% if logoFooter %}
        <img class="object-contain w-fit"
          src="{{ logoFooter.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', logoFooter.id)}}"
          data-sizes="auto"
          fetchpriority="high"
          alt="{{ logoFooter.alt|e }}">
      {% endif %}
    </div>
  </div>
</flynt-component>
