              <path d="M25.7092 3.97778C25.7092 3.97778 16.5524 11.1149 12.4485 14.8984C12.2984 15.0367 12.2068 15.1988 12.1714 15.3737C11.9899 16.2707 11.333 19.2531 10.2004 21.5377" stroke="#28321E" stroke-linecap="round" stroke-linejoin="round"/>
