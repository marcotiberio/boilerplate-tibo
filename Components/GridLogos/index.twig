<flynt-component 
  load:on="visible" 
  name="GridLogos"
  style="
    color: {% if options.colorText %}{{ options.colorText }}{% else %}var(--black){% endif %};
    background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}transparent{% endif %};">
  <div class="boxed flex flex-col gap-xs lg:gap-sm">
    {% if blockTitle %}
      <h3 class="font-nav text-center">{{ blockTitle }}</h3>
    {% endif %}
    <div 
      class="w-full mx-auto grid gap-xs
      {% if options.gridColumns == '1' %} grid-cols-2 sm:grid-cols-2 lg:grid-cols-2
      {% elseif options.gridColumns == '2' %} grid-cols-2 sm:grid-cols-2 lg:grid-cols-2
      {% elseif options.gridColumns == '3' %} grid-cols-2 sm:grid-cols-2 lg:grid-cols-3
      {% elseif options.gridColumns == '4' %} grid-cols-2 sm:grid-cols-2 lg:grid-cols-4
      {% elseif options.gridColumns == '5' %} grid-cols-2 sm:grid-cols-3 lg:grid-cols-5
      {% endif %}">
      {% for item in items %}
        <div class="flex flex-col gap-xs">
          {% if item.image %}
            {% if item.image.post_mime_type == 'image/svg+xml'%}
              <figure class="figure p-sm flex flex-row justify-start items-start">
                <img class="lazyload w-full mx-auto h-full object-contain"
                  src="{{ item.image.src | resize(32) }}"
                  data-srcset="{{function('wp_get_attachment_image_srcset', item.image.id)}}"
                  data-sizes="auto"
                  alt="{{ item.image.alt|e }}">
              </figure>
            {% else %}
                <figure class="figure figureImage w-full">
                  <img class="lazyload w-full mx-auto h-full object-contain"
                    src="{{ item.image.src | resize(32) }}"
                    data-srcset="{{function('wp_get_attachment_image_srcset', item.image.id)}}"
                    data-sizes="auto"
                    alt="{{ item.image.alt|e }}">
                </figure>
            {% endif %}
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</flynt-component>
