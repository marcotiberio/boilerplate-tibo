<flynt-component 
  load:on="visible" 
  name="BlockWysiwygColumns"
  class="{% if options.firstComponent %}pt-[10vw] md:pt-[160px]{% endif %}"
  style="
    background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}transparent{% endif %};"
  >
  <div class="boxed w-full flex flex-col gap-sm">
    {% if blockTitle %}
      <div class="">
        <h2 class="font-h2">{{ blockTitle|e }}</h2>
      </div>
    {% endif %}
    <div class="flex flex-col md:flex-row gap-y-lg lg:gap-sm">
      {% for column in columns %}
        <div class="flex flex-col w-full">
          {% if column.image %}
            <img 
              class="figure-image lazyload w-full max-w-[33%] object-cover mb-xs"
              src="{{ column.image.src }}"
              alt="{{ column.image.alt|e | default('') }}"
              loading="lazy"
              style="opacity: 0; transition: opacity 0.5s ease-in-out;"
              onload="this.style.opacity='1'"
            />
          {% endif %}
          <div class="wysiwyg">{{ column.contentHtml|e('wp_kses_post') }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</flynt-component> 